rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. users 컬렉션 (유저 정보 및 결제 토큰)
    match /users/{userId} {
      // 본인만 읽기 가능
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // 첫 로그인 가입 시 생성 (freeTokens 무조건 30으로 시작, 플랜 강제 지정 불가)
      allow create: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.freeTokens == 30
                    && (!request.resource.data.keys().hasAny(['plan']));
                    
      // 토큰 1개 차감만 클라이언트에서 허용 (나머지 필드는 건드리지 못함)
      allow update: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['freeTokens'])
                    && (request.resource.data.freeTokens == resource.data.freeTokens - 1 || request.resource.data.freeTokens == resource.data.freeTokens + 1);

      // 사용자의 구매 에셋
      match /purchasedAssets/{assetId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId; // 임시: 가상 결제 테스트 허용
      }
    }

    // 2. 관리자 (admin) 전용 통과 파이프라인
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.email in ['dyt8401@gmail.com', 'admin@questio.co.kr', 'kangwoner@gmail.com'];
    }

    // 3. 에셋 스토어 콜렉션
    match /assets/{assetId} {
      allow read: if request.auth != null; // 상점에 접속한 누구나 열람 가능
      allow write: if request.auth != null; // 임시: 관리자 외에도 테스트 가능하도록 완화
    }

    // 4. 문제은행 (questions) 콜렉션
    match /questions/{questionId} {
      allow read: if true; // 누구나 통합 문제은행 리스트 다운로드 및 검색 가능
    }

    // 5. 학원 환경설정 콜렉션
    match /academySettings/{adminId} {
      allow read: if true; // 누구나 읽기 가능 (학원 이름 노출용)
    }
  }
}
